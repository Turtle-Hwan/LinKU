{
  "name": "@linku/extension",
  "private": true,
  "version": "1.5.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite --config ./vite.config.ts --mode development",
    "build": "node ./scripts/updateVersion.js && tsc -b ./tsconfig.json && vite build --config ./vite.config.ts --mode production",
    "build:local": "tsc -b ./tsconfig.json && vite build --config ./vite.config.ts --mode development",
    "watch": "node ./scripts/updateVersion.js && tsc -b ./tsconfig.json && vite build --config ./vite.config.ts --watch --mode production",
    "watch:local": "tsc -b ./tsconfig.json && vite build --config ./vite.config.ts --watch --mode development",
    "build:gh-pages": "tsc -b ./tsconfig.json && vite build --config ./vite.config.ts --mode gh-pages",
    "typecheck": "tsc -b ./tsconfig.json",
    "lint": "eslint .",
    "preview": "vite preview --config ./vite.config.ts",
    "deploy": "git subtree push --prefix apps/extension/gh-pages origin gh-pages"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@linku/config": "workspace:*",
    "@linku/platform": "workspace:*",
    "@linku/shared-types": "workspace:*",
    "@linku/ui": "workspace:*",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.1",
    "@types/chrome": "^0.1.37",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.577.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "install": "^0.13.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0"
  }
}
