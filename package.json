{
  "name": "linku-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.4.0",
  "scripts": {
    "dev": "pnpm --filter @linku/extension dev",
    "build": "pnpm --filter @linku/extension build",
    "build:local": "pnpm --filter @linku/extension build:local",
    "watch": "pnpm --filter @linku/extension watch",
    "watch:local": "pnpm --filter @linku/extension watch:local",
    "build:gh-pages": "pnpm --filter @linku/extension build:gh-pages",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "preview": "pnpm --filter @linku/extension preview",
    "deploy": "pnpm --filter @linku/extension deploy"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^15.15.0",
    "typescript-eslint": "^8.48.0"
  }
}
